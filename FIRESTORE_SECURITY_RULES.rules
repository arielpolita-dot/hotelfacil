rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Função para verificar se o usuário está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Função para verificar se o usuário pertence à empresa
    function belongsToCompany(empresaId) {
      return isAuthenticated() && 
             request.auth.token.empresaId == empresaId;
    }
    
    // Função para verificar se o usuário tem permissão específica
    function hasPermission(empresaId, permission) {
      return belongsToCompany(empresaId) && 
             get(/databases/$(database)/documents/empresas/$(empresaId)/usuarios/$(request.auth.uid)).data.permissoes[permission] == true;
    }
    
    // Função para verificar se é administrador
    function isAdmin(empresaId) {
      return belongsToCompany(empresaId) && 
             get(/databases/$(database)/documents/empresas/$(empresaId)/usuarios/$(request.auth.uid)).data.funcao == 'administrador';
    }
    
    // Função para verificar se é o próprio usuário
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Regras para empresas
    match /empresas/{empresaId} {
      // Dados da empresa - apenas usuários da empresa podem ler, apenas admin pode escrever
      match /dados {
        allow read: if belongsToCompany(empresaId);
        allow write: if isAdmin(empresaId);
      }
      
      // Quartos - permissão baseada no módulo 'quartos'
      match /quartos/{quartoId} {
        allow read: if hasPermission(empresaId, 'quartos') || hasPermission(empresaId, 'disponibilidade') || hasPermission(empresaId, 'vendas');
        allow create, update: if hasPermission(empresaId, 'quartos');
        allow delete: if isAdmin(empresaId);
      }
      
      // Reservas - permissão baseada no módulo 'vendas'
      match /reservas/{reservaId} {
        allow read: if hasPermission(empresaId, 'vendas') || hasPermission(empresaId, 'dashboard');
        allow create, update: if hasPermission(empresaId, 'vendas');
        allow delete: if isAdmin(empresaId);
      }
      
      // Contratos corporativos - permissão baseada no módulo 'faturas'
      match /contratos/{contratoId} {
        allow read: if hasPermission(empresaId, 'faturas') || hasPermission(empresaId, 'dashboard');
        allow create, update: if hasPermission(empresaId, 'faturas');
        allow delete: if isAdmin(empresaId);
      }
      
      // Faturas - permissão baseada no módulo 'faturas'
      match /faturas/{faturaId} {
        allow read: if hasPermission(empresaId, 'faturas') || hasPermission(empresaId, 'fluxoCaixa');
        allow create, update: if hasPermission(empresaId, 'faturas');
        allow delete: if isAdmin(empresaId);
      }
      
      // Despesas - permissão baseada no módulo 'despesas'
      match /despesas/{despesaId} {
        allow read: if hasPermission(empresaId, 'despesas') || hasPermission(empresaId, 'fluxoCaixa') || hasPermission(empresaId, 'dashboard');
        allow create, update: if hasPermission(empresaId, 'despesas');
        allow delete: if isAdmin(empresaId);
      }
      
      // Fluxo de caixa - permissão baseada no módulo 'fluxoCaixa'
      match /fluxoCaixa/{transacaoId} {
        allow read: if hasPermission(empresaId, 'fluxoCaixa') || hasPermission(empresaId, 'dashboard');
        allow create, update: if hasPermission(empresaId, 'fluxoCaixa') || hasPermission(empresaId, 'vendas') || hasPermission(empresaId, 'despesas');
        allow delete: if isAdmin(empresaId);
      }
      
      // Usuários - permissão especial
      match /usuarios/{userId} {
        // Usuários podem ler seus próprios dados ou se tiverem permissão de usuários
        allow read: if isOwner(userId) || hasPermission(empresaId, 'usuarios');
        
        // Apenas usuários com permissão de usuários podem criar novos usuários
        allow create: if hasPermission(empresaId, 'usuarios');
        
        // Usuários podem atualizar seus próprios dados (exceto permissões) ou admin pode atualizar qualquer um
        allow update: if (isOwner(userId) && !('permissoes' in resource.data) && !('funcao' in resource.data)) || 
                         hasPermission(empresaId, 'usuarios');
        
        // Apenas admin pode deletar usuários (exceto a si mesmo)
        allow delete: if isAdmin(empresaId) && !isOwner(userId);
      }
      
      // Configurações - apenas admin
      match /configuracoes/{configId} {
        allow read: if belongsToCompany(empresaId);
        allow write: if isAdmin(empresaId);
      }
      
      // Auditoria - apenas leitura para admin, escrita automática pelo sistema
      match /auditoria/{logId} {
        allow read: if isAdmin(empresaId);
        allow create: if belongsToCompany(empresaId); // Permite que qualquer usuário da empresa crie logs
        allow update, delete: if false; // Logs não podem ser alterados ou deletados
      }
    }
    
    // Regras para dados públicos (se houver)
    match /public/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    
    // Regras para metadados do sistema
    match /system/{document=**} {
      allow read, write: if false; // Apenas o servidor pode acessar
    }
    
    // Regra padrão - negar tudo que não foi explicitamente permitido
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

// Regras adicionais para Storage (se usar Firebase Storage)
