

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------
    // Funções de Apoio (Helpers)
    // --------------------------------

    // Verifica se o usuário está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }

    // Verifica se o UID do usuário corresponde ao ID do documento de usuário
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Obtém os dados do usuário que está fazendo a requisição
    function getUserData(empresaId) {
      return get(/databases/$(database)/documents/empresas/$(empresaId)/usuarios/$(request.auth.uid)).data;
    }

    // Verifica se o usuário pertence à empresa especificada no token de autenticação
    function belongsToCompany(empresaId) {
      return isAuthenticated() && request.auth.token.empresaId == empresaId;
    }

    // Verifica se o usuário tem uma função específica (e.g., 'administrador', 'gerente')
    function hasRole(empresaId, role) {
      let userData = getUserData(empresaId);
      return belongsToCompany(empresaId) && userData.acesso.funcao == role;
    }

    // Verifica se o usuário tem uma permissão específica para um módulo (e.g., 'quartos', 'vendas')
    function hasPermission(empresaId, permission) {
      let userData = getUserData(empresaId);
      return belongsToCompany(empresaId) && userData.permissoes[permission] == true;
    }

    // Verifica se o usuário é um Administrador
    function isAdmin(empresaId) {
      return hasRole(empresaId, 'Administrador');
    }

    // Verifica se o usuário é um Gerente
    function isManager(empresaId) {
      return hasRole(empresaId, 'Gerente');
    }

    // Verifica se os campos de auditoria (criado_em, criado_por) não estão sendo modificados
    function isNotUpdatingAuditFields() {
      return !('criado_em' in request.resource.data) && !('criado_por' in request.resource.data);
    }

    // Verifica se o campo 'atualizado_em' está sendo definido com o tempo do servidor
    function isUpdatingTimestamp() {
      return request.resource.data.atualizado_em == request.time;
    }

    // --------------------------------
    // Regras de Acesso por Coleção
    // --------------------------------

    match /empresas/{empresaId} {

      // --- DADOS DA EMPRESA ---
      match /dados_empresa/{docId} {
        allow read: if belongsToCompany(empresaId);
        allow write: if isAdmin(empresaId) && isNotUpdatingAuditFields() && isUpdatingTimestamp();
      }

      // --- QUARTOS ---
      match /quartos/{quartoId} {
        allow read: if hasPermission(empresaId, 'disponibilidade') || hasPermission(empresaId, 'quartos');
        allow create: if hasPermission(empresaId, 'quartos');
        allow update: if hasPermission(empresaId, 'quartos') && isNotUpdatingAuditFields() && isUpdatingTimestamp();
        allow delete: if isAdmin(empresaId);
      }

      // --- HÓSPEDES ---
      match /hospedes/{hospedeId} {
        allow read, create, update: if hasPermission(empresaId, 'vendas');
        allow delete: if isManager(empresaId) || isAdmin(empresaId);
      }

      // --- RESERVAS ---
      match /reservas/{reservaId} {
        allow read: if hasPermission(empresaId, 'vendas') || hasPermission(empresaId, 'dashboard');
        allow create: if hasPermission(empresaId, 'vendas');
        allow update: if hasPermission(empresaId, 'vendas') && isNotUpdatingAuditFields() && isUpdatingTimestamp();
        allow delete: if isManager(empresaId) || isAdmin(empresaId);
      }

      // --- CONTRATOS CORPORATIVOS ---
      match /contratos_corporativos/{contratoId} {
        allow read: if hasPermission(empresaId, 'faturas');
        allow create: if hasPermission(empresaId, 'faturas');
        allow update: if hasPermission(empresaId, 'faturas') && isNotUpdatingAuditFields() && isUpdatingTimestamp();
        allow delete: if isAdmin(empresaId);
      }

      // --- FATURAS ---
      match /faturas/{faturaId} {
        allow read: if hasPermission(empresaId, 'faturas') || hasPermission(empresaId, 'fluxo_caixa');
        allow create, update: if hasPermission(empresaId, 'faturas');
        allow delete: if isAdmin(empresaId);
      }

      // --- DESPESAS ---
      match /despesas/{despesaId} {
        allow read: if hasPermission(empresaId, 'despesas') || hasPermission(empresaId, 'fluxo_caixa');
        allow create, update: if hasPermission(empresaId, 'despesas');
        allow delete: if isManager(empresaId) || isAdmin(empresaId);
      }

      // --- FLUXO DE CAIXA ---
      match /fluxo_caixa/{transacaoId} {
        allow read: if hasPermission(empresaId, 'fluxo_caixa') || hasPermission(empresaId, 'dashboard');
        // A criação é geralmente automática, mas pode ser manual pelo financeiro
        allow create: if hasPermission(empresaId, 'fluxo_caixa'); 
        allow update, delete: if isAdmin(empresaId);
      }

      // --- USUÁRIOS ---
      match /usuarios/{userId} {
        // Um usuário pode ler seus próprios dados. Usuários com permissão 'usuarios' podem ler qualquer um.
        allow read: if isOwner(userId) || hasPermission(empresaId, 'usuarios');

        // Apenas quem tem permissão 'usuarios' pode criar novos usuários.
        allow create: if hasPermission(empresaId, 'usuarios');

        // Um usuário pode atualizar seus próprios dados (exceto função e permissões).
        // Quem tem permissão 'usuarios' pode atualizar qualquer um.
        allow update: if (isOwner(userId) && !('acesso' in request.resource.data) && !('permissoes' in request.resource.data)) || hasPermission(empresaId, 'usuarios');

        // Apenas administradores podem deletar usuários, e não podem deletar a si mesmos.
        allow delete: if isAdmin(empresaId) && !isOwner(userId);
      }

      // --- CONFIGURAÇÕES DO HOTEL ---
      match /configuracoes_hotel/{configId} {
        allow read: if belongsToCompany(empresaId);
        allow write: if isAdmin(empresaId);
      }
    }

    // Regra para negar acesso a qualquer outro caminho não especificado
    match /{path=**} {
      allow read, write: if false;
    }
  }
}

